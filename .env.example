# ─────────────────────────────────────────────────────────────
# Shyft — Environment variables
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit `.env.local` (it's in .gitignore).
# ─────────────────────────────────────────────────────────────

# === Solana RPC (Helius) ─────────────────────────────────────
# Public key — exposed to the browser. Get free key at https://helius.dev
NEXT_PUBLIC_HELIUS_API_KEY=your_helius_public_key

# Private key — server-only (used by /api/rpc, /api/stats, /api/bags, etc.)
HELIUS_API_KEY_PRIVATE=your_helius_private_key

# === Treasury (sponsors all user gas + rent) ─────────────────
# JSON byte array of the treasury Solana keypair (Uint8Array).
# Example shape:  [12,34,56, ...]   (64 numbers, NO quotes around the array)
TREASURY_PRIVATE_KEY=[]

# === Privy (embedded wallets) ────────────────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# === Bags SDK (creator tokens) ───────────────────────────────
# Get from https://bags.fm (partner program)
BAGS_API_KEY=your_bags_api_key
BAGS_PARTNER_WALLET=your_bags_partner_wallet_pubkey
BAGS_PARTNER_CONFIG_PDA=B94bGwVuX7tWX8VkkyBZLmQESJ537URMcJcVkF8tdi5T

# === Pinata (IPFS image/video uploads) ───────────────────────
# Get from https://pinata.cloud
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=your-gateway.mypinata.cloud

# === xAI / Grok (AI assistant button) ────────────────────────
# Optional — disables the floating AI button if missing.
XAI_API_KEY=your_xai_api_key

# === GIF picker (optional) ───────────────────────────────────
TENOR_API_KEY=your_tenor_key
GIPHY_API_KEY=your_giphy_key

# === LiveKit (voice/video calls) ─────────────────────────────
# Optional — disables voice rooms if missing. https://livekit.io
LIVEKIT_API_KEY=your_livekit_key
LIVEKIT_API_SECRET=your_livekit_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# === Upstash Redis / Vercel KV (push notifications + reports) ─
# Optional — push subscriptions/report storage will be disabled if missing.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# OR (alternative names — Vercel KV uses these)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# === Resend (email for reports) ──────────────────────────────
# Optional — only used by the /api/report endpoint.
RESEND_API_KEY=
REPORT_EMAIL=you@example.com

# === Cron / webhooks ─────────────────────────────────────────
# Shared secret protecting /api/push/cron + /api/report (POST)
CRON_SECRET=generate_a_long_random_string
# Shared secret protecting /api/push/send
PUSH_API_SECRET=generate_a_long_random_string
# Set to "1" to disable /api/push/test in production
PUSH_TEST_DISABLED=0
